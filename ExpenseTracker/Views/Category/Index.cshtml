@model IEnumerable<ExpenseTracker.Models.Category>
<a asp-controller="Dashboard" asp-action="Index"
   class="btn btn-outline-secondary mt-3">
    ← Back to Dashboard
</a>
<div class="text-end mb-4 mt-3">
    
    <a asp-controller="Transaction" asp-action="Index"
       class="btn btn-outline-primary me-3">
         Go to Transaction
    </a>
    <a class="btn btn-primary"  asp-action="Add">+ Add Category</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-striped mt-3">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Icon</th>
            <th>Type</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>
                    <i class="@item.Icon" style="font-size:20px;"></i>
                </td>
                <td>
                    @if (item.Type == "Expense")
                    {
                        <span class="badge bg-danger">Expense</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Income</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning me-3">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>